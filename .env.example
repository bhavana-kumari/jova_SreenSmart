# Google Gemini API key (from Google AI Studio)
GEMINI_API_KEY=your_gemini_api_key_here

# n8n webhook URL — called only when fit is "Strong Fit"
N8N_WEBHOOK=https://your-n8n-instance.com/webhook/screensmart

# Server port
PORT=5000

# Optional: Gemini model name (default: gemini-flash-lite-latest)
GEMINI_MODEL=gemini-flash-lite-latest
